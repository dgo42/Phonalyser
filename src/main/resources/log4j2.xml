<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%-5level] %msg%n"/>
        </Console>
        <RollingFile name="File"
                     fileName="${sys:app.log.dir:-logs}/phonalyser.log"
                     filePattern="${sys:app.log.dir:-logs}/phonalyser-%d{yyyy-MM-dd}.log">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%-5level] %logger{36} - %msg%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy/>
            </Policies>
        </RollingFile>
    </Appenders>
    <Loggers>
        <!-- PortAudio native-library loading logs at INFO (which DLL / folder was
             resolved) for field diagnostics, without raising the rest of the app
             above WARN. -->
        <Logger name="org.edgo.audio.measure.sound.PortAudio" level="INFO" additivity="false">
            <AppenderRef ref="Console" level="ERROR"/>
            <AppenderRef ref="File"/>
        </Logger>
        <Root level="WARN">
            <AppenderRef ref="Console" level="ERROR" />
            <AppenderRef ref="File" level="WARN" />
        </Root>
    </Loggers>
</Configuration>
